<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Outdoor Plants | BloomHub</title>

  <!-- SEO -->
  <meta name="description" content="Shop the best outdoor plants at BloomHub. Hardy, colorful, and perfect for Indian gardens.">
  <meta name="keywords" content="outdoor plants, Indian climate plants, garden plants, bloomhub">
  <meta name="author" content="BloomHub">
  <link rel="icon" href="<%= '/images/favicon.ico' %>" />

  <!-- CSS -->
  <link rel="stylesheet" href="<%= '/css/indoor.css' %>"> <!-- ✅ reuse indoor.css for same card sizes -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

  <!-- ✅ Header -->
  <header>
    <div class="logo">
      <img src="<%= '/images/logo.jpg' %>" alt="BloomHub Logo" />
      <h1>BloomHub</h1>
    </div>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/shop">Shop</a></li>
        <li><a href="/categories">Categories</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
    <div class="search-cart">
      <input type="text" placeholder="Search plants..." />
      <button class="icon-btn" aria-label="Search"><i class="fas fa-search"></i></button>
      <button class="icon-btn" aria-label="Cart"><i class="fas fa-shopping-cart"></i></button>
      <a href="/login" class="icon-btn" aria-label="Profile"><i class="fas fa-user"></i></a>
    </div>
  </header>

  <!-- ✅ Outdoor Plants Section -->
  <main>
    <div class="container">
      <h2>Outdoor Plants</h2>
      <div class="cards">

        <div class="card">
          <img src="/images/hibiscus.jpeg" alt="Hibiscus">
          <h3>Hibiscus (Gudhal)</h3>
          <p>₹399</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/bougainvillea.jpeg" alt="Bougainvillea">
          <h3>Bougainvillea</h3>
          <p>₹299</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/marigold.jpeg" alt="Marigold">
          <h3>Marigold (Genda)</h3>
          <p>₹199</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/jasmine.jpeg" alt="Jasmine">
          <h3>Jasmine (Mogra/Chameli)</h3>
          <p>₹249</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/ixora.jpeg" alt="Ixora">
          <h3>Ixora</h3>
          <p>₹349</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/roses.jpeg" alt="Roses">
          <h3>Roses</h3>
          <p>₹499</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/tulsi.jpeg" alt="Tulsi">
          <h3>Tulsi (Holy Basil)</h3>
          <p>₹149</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/adenium.jpeg" alt="Adenium">
          <h3>Adenium (Desert Rose)</h3>
          <p>₹599</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/chrysanthemums.jpeg" alt="Chrysanthemums">
          <h3>Chrysanthemums</h3>
          <p>₹349</p>
          <button>View Product</button>
        </div>

        <div class="card">
          <img src="/images/ashoka.jpeg" alt="Ashoka Tree">
          <h3>Ashoka Tree</h3>
          <p>₹799</p>
          <button>View Product</button>
        </div>

      </div>
    </div>
  </main>

  <!-- ✅ Footer (same as indoor/home) -->
  <footer class="site-footer">
    <div class="footer-container">
      <div class="footer-col">
        <h4>ABOUT US</h4>
        <ul>
          <li><a href="#">Our Story</a></li>
          <li><a href="#">Contact Us</a></li>
          <li><a href="#">Careers</a></li>
          <li><a href="#">Locate Stores</a></li>
          <li><a href="#">Own Grown</a></li>
          <li><a href="#">Garden Services & Maintenance</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>CUSTOMER CARE</h4>
        <ul>
          <li><a href="/quiz">Take The Plant Quiz</a></li>
          <li><a href="#">Track Order</a></li>
          <li><a href="#">Shipping Policy</a></li>
          <li><a href="#">Terms and Conditions</a></li>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">FAQs</a></li>
          <li><a href="#">Refund Policy</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>OFFERS & REWARDS</h4>
        <ul>
          <li><a href="#">Plant Parent Rewards Club</a></li>
          <li><a href="#">BloomHub Coupons</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>GET IN TOUCH</h4>
        <p>WhatsApp us at: <a href="https://chat.whatsapp.com/Gg2OTYdk4zp0GN1eAxr8oS">9815517131</a></p>
        <p>Call: <a href="tel:+91987654321">+91 91987654321</a></p>
        <p>Email: <a href="mailto:support@bloomhub.com">support@bloomhub.com</a></p>
      </div>

      <div class="footer-col newsletter-col">
        <h4>SIGN UP FOR OUR NEWSLETTER</h4>
        <form>
          <input type="email" placeholder="Enter email address" required />
          <button type="submit">→</button>
        </form>
        <p>For plant care tips, our featured plant of the week, exclusive offers and discounts</p>
        <div class="social-icons">
          <a href="#"><i class="fas fa-leaf"></i></a>
          <a href="#"><i class="fab fa-facebook"></i></a>
          <a href="#"><i class="fab fa-instagram"></i></a>
          <a href="#"><i class="fab fa-linkedin"></i></a>
          <a href="#"><i class="fab fa-youtube"></i></a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2025 BloomHub | Crafted with <i class="fas fa-leaf"></i> for Plant Lovers</p>
    </div>
  </footer>

</body>
</html>
