        </div>
        <div class="footer-bottom">
            <p>© 2025 BloomHub | Crafted with <i class="fas fa-leaf"></i> for Plant Lovers</p>
        </div>
    </footer>
</body>
</html>
<script>
  function toggleInfo() {
    const msg = document.getElementById("info-message");
    msg.style.display = (msg.style.display === "block") ? "none" : "block";
  }
</script>
